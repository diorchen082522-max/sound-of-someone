<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Sound of Glasses</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div class="header-content">
                <h1 class="title">🥂 The Sound of Glasses</h1>
                <p class="subtitle">An Interactive Journey Through Glass Acoustics</p>
                <p class="artist">by Ziya Chen</p>
            </div>
        </header>

        <!-- Intro Section -->
        <section class="intro">
            <h2>Listen. Explore. Feel.</h2>
            <p>Glass is a living instrument. Every touch creates a unique sound. 
               Click on each glass to discover the sonic landscape hidden within transparency.</p>
        </section>

        <!-- Interactive Glass Grid -->
        <section class="glass-grid">
            <!-- Glass 1: Wine Glass Ring -->
            <div class="glass-card" data-sound="1">
                <div class="glass-visual glass-1"></div>
                <h3>Wine Glass Ring</h3>
                <p class="description">The classic finger-rim vibration</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 2: Champagne Flute Clink -->
            <div class="glass-card" data-sound="2">
                <div class="glass-visual glass-2"></div>
                <h3>Champagne Flute Clink</h3>
                <p class="description">Two glasses celebrating together</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 3: Water Pour -->
            <div class="glass-card" data-sound="3">
                <div class="glass-visual glass-3"></div>
                <h3>Water Pour</h3>
                <p class="description">Liquid resonance filling emptiness</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 4: Tap with Spoon -->
            <div class="glass-card" data-sound="4">
                <div class="glass-visual glass-4"></div>
                <h3>Tap with Spoon</h3>
                <p class="description">Metal meets crystal clarity</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 5: Martini Glass Swirl -->
            <div class="glass-card" data-sound="5">
                <div class="glass-visual glass-5"></div>
                <h3>Martini Glass Swirl</h3>
                <p class="description">Liquid dancing in geometric form</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 6: Ice Cube Drop -->
            <div class="glass-card" data-sound="6">
                <div class="glass-visual glass-6"></div>
                <h3>Ice Cube Drop</h3>
                <p class="description">Cold percussion on glass floor</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 7: Shot Glass Snap -->
            <div class="glass-card" data-sound="7">
                <div class="glass-visual glass-7"></div>
                <h3>Shot Glass Snap</h3>
                <p class="description">Rapid high-frequency shimmer</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 8: Beer Glass Slide -->
            <div class="glass-card" data-sound="8">
                <div class="glass-visual glass-8"></div>
                <h3>Beer Glass Slide</h3>
                <p class="description">Texture against smooth surface</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 9: Wine Glass Resonance -->
            <div class="glass-card" data-sound="9">
                <div class="glass-visual glass-9"></div>
                <h3>Wine Glass Resonance</h3>
                <p class="description">Sustained harmonic depth</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>

            <!-- Glass 10: Shattered Echo -->
            <div class="glass-card" data-sound="10">
                <div class="glass-visual glass-10"></div>
                <h3>Shattered Echo</h3>
                <p class="description">The final moment of transformation</p>
                <button class="play-btn">Play</button>
                <div class="visualizer"></div>
            </div>
        </section>

        <!-- Statistics Section -->
        <section class="stats">
            <div class="stat">
                <h4>10</h4>
                <p>Unique Sounds</p>
            </div>
            <div class="stat">
                <h4 id="total-plays">0</h4>
                <p>Total Plays</p>
            </div>
