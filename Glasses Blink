</html>


* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary: #1a1a2e;
    --secondary: #16213e;
    --accent: #0f3460;
    --highlight: #e94560;
    --light: #eaeaea;
    --gold: #d4af37;
    --glass-blue: #a8d8ff;
    --glass-purple: #d4a5ff;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: var(--light);
    overflow-x: hidden;
    min-height: 100vh;
}

/* Header */
.header {
    background: linear-gradient(135deg, var(--accent) 0%, var(--highlight) 100%);
    padding: 60px 20px;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    position: relative;
    overflow: hidden;
}

.header::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(212, 175, 255, 0.1) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: float 20s linear infinite;
}

@keyframes float {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
}

.header-content {
    position: relative;
    z-index: 1;
}

.title {
    font-size: 3.5em;
    margin-bottom: 10px;
    font-weight: 700;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    letter-spacing: 2px;
}

.subtitle {
    font-size: 1.3em;
    margin-bottom: 10px;
    opacity: 0.9;
}

.artist {
    font-size: 1em;
    opacity: 0.8;
    font-style: italic;
    color: var(--gold);
}

/* Intro Section */
.intro {
    padding: 50px 20px;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    animation: slideUp 0.8s ease-out;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.intro h2 {
    font-size: 2.5em;
    margin-bottom: 20px;
    background: linear-gradient(135deg, var(--glass-blue), var(--glass-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.intro p {
    font-size: 1.1em;
    opacity: 0.85;
    line-height: 1.8;
}

/* Glass Grid */
.glass-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    padding: 50px 20px;
    max-width: 1400px;
    margin: 0 auto;
}

.glass-card {
    background: linear-gradient(135deg, rgba(26, 26, 46, 0.8), rgba(15, 52, 96, 0.8));
    border: 2px solid var(--glass-blue);
    border-radius: 20px;
    padding: 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
}

.glass-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(212, 175, 255, 0.1) 0%, transparent 70%);
    pointer-events: none;
    transition: all 0.5s ease;
}

.glass-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 60px rgba(233, 69, 96, 0.3);
    border-color: var(--gold);
    background: linear-gradient(135deg, rgba(26, 26, 46, 0.95), rgba(15, 52, 96, 0.95));
}

.glass-card:hover::before {
    top: 50%;
    left: 50%;
}

.glass-card h3 {
    font-size: 1.5em;
    margin: 20px 0 10px 0;
    color: var(--gold);
}

.description {
    font-size: 0.95em;
    opacity: 0.75;
    margin-bottom: 20px;
    font-style: italic;
}

/* Glass Visual */
.glass-visual {
    height: 200px;
    margin-bottom: 20px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--glass-blue), var(--glass-purple));
    position: relative;
    box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 80px;
}

.glass-1 { background: linear-gradient(135deg, #ff6b6b, #ee5a6f); }
.glass-2 { background: linear-gradient(135deg, #4ecdc4, #44a08d); }
.glass-3 { background: linear-gradient(135deg, #45b7d1, #2196f3); }
.glass-4 { background: linear-gradient(135deg, #f093fb, #f5576c); }
.glass-5 { background: linear-gradient(135deg, #ffd89b, #19547b); }
.glass-6 { background: linear-gradient(135deg, #a8edea, #fed6e3); }
.glass-7 { background: linear-gradient(135deg, #ff9a56, #ff6a88); }
.glass-8 { background: linear-gradient(135deg, #ffecd2, #fcb69f); }
.glass-9 { background: linear-gradient(135deg, #ff6e7f, #bfe9ff); }
.glass-10 { background: linear-gradient(135deg, #c084fc, #e879f9); }

/* Play Button */
.play-btn {
    background: linear-gradient(135deg, var(--highlight), #ff6b9d);
    color: white;
    border: none;
    padding: 12px 30px;
    border-radius: 25px;
    font-size: 1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 15px;
    box-shadow: 0 4px 15px rgba(233, 69, 96, 0.3);
}

.play-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(233, 69, 96, 0.5);
}

.play-btn:active {
    transform: scale(0.98);
}

.play-btn.playing {
    background: linear-gradient(135deg, var(--gold), #f5b041);
    animation: pulse 0.5s ease-in-out;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

/* Visualizer */
.visualizer {
    height: 40px;
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    gap: 5px;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.glass-card:hover .visualizer {
    opacity: 1;
}

.visualizer::before {
    content: '';
    display: block;
    width: 8%;
    height: 30%;
    background: var(--highlight);
    border-radius: 4px;
    animation: bar1 0.5s ease-in-out infinite;
}

.visualizer::after {
    content: '';
    display: block;
    width: 8%;
    height: 50%;
    background: var(--gold);
    border-radius: 4px;
    animation: bar2 0.5s ease-in-out infinite 0.1s;
}

@keyframes bar1 {
    0%, 100% { height: 20%; }
    50% { height: 60%; }
}

@keyframes bar2 {
    0%, 100% { height: 40%; }
    50% { height: 80%; }
}

/* Stats Section */
.stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
    padding: 50px 20px;
    max-width: 800px;
    margin: 0 auto;
}

.stat {
    background: linear-gradient(135deg, var(--accent), var(--secondary));
    padding: 30px;
    border-radius: 15px;
    text-align: center;
    border: 2px solid var(--glass-purple);
}

.stat h4 {
    font-size: 2.5em;
    color: var(--gold);
    margin-bottom: 10px;
}

.stat p {
    font-size: 1em;
    opacity: 0.8;
}

/* Controls */
.controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    padding: 40px 20px;
    flex-wrap: wrap;
}

.control-btn {
    background: linear-gradient(135deg, var(--accent), var(--highlight));
    color: white;
    border: none;
    padding: 12px 25px;
    border-radius: 25px;
    font-size: 1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.control-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 20px rgba(233, 69, 96, 0.4);
}

.volume-slider {
    width: 150px;
    height: 6px;
    border-radius: 3px;
    background: var(--accent);
    outline: none;
    -webkit-appearance: none;
}

.volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--gold);
    cursor: pointer;
    box-shadow: 0 0 10px rgba(212, 175, 255, 0.5);
}

.volume-slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--gold);
    cursor: pointer;
    border: none;
    box-shadow: 0 0 10px rgba(212, 175, 255, 0.5);
}

/* Footer */
.footer {
    text-align: center;
    padding: 40px 20px;
    border-top: 2px solid var(--accent);
    opacity: 0.7;
    margin-top: 40px;
}

.footer p {
    margin: 5px 0;
    font-size: 0.95em;
}

/* Responsive */
@media (max-width: 768px) {
    .title {
        font-size: 2.5em;
    }

    .subtitle {
        font-size: 1em;
    }

    .intro h2 {
        font-size: 1.8em;
    }

    .glass-grid {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        padding: 30px 15px;
    }

    .controls {
        flex-direction: column;
    }

    .volume-slider {
        width: 100%;
        max-width: 200px;
    }
}

// Audio context and synthesis
const audioContext = new (window.AudioContext || window.webkitAudioContext)();
let currentlyPlaying = new Set();
let totalPlays = 0;
let favorites = new Set();

// Glass sound definitions
const glassSounds = [
    {
        id: 1,
        name: "Wine Glass Ring",
        frequencies: [800, 1200, 1600],
        duration: 2.5,
        type: "sine"
    },
    {
        id: 2,
        name: "Champagne Flute Clink",
        frequencies: [1200, 1800],
        duration: 0.8,
        type: "sine"
    },
    {
        id: 3,
        name: "Water Pour",
        frequencies: [400, 600, 800],
        duration: 2,
        type: "triangle"
    },
    {
        id: 4,
        name: "Tap with Spoon",
        frequencies: [2000, 3000, 4000],
        duration: 0.4,
        type: "sine"
    },
    {
        id: 5,
        name: "Martini Glass Swirl",
        frequencies: [1000, 1500, 2000],
        duration: 1.5,
        type: "square"
    },
    {
        id: 6,
        name: "Ice Cube Drop",
        frequencies: [600, 1000, 1400],
        duration: 1.2,
        type: "triangle"
    },
    {
        id: 7,
        name: "Shot Glass Snap",
        frequencies: [2500, 3500],
        duration: 0.3,
        type: "sine"
    },
    {
        id: 8,
        name: "Beer Glass Slide",
        frequencies: [500, 700, 900],
        duration: 1.8,
        type: "sawtooth"
    },
    {
        id: 9,
        name: "Wine Glass Resonance",
        frequencies: [700, 1400, 2100],
        duration: 3,
        type: "sine"
    },
    {
        id: 10,
        name: "Shattered Echo",
        frequencies: [3000, 4000, 5000, 6000],
        duration: 0.6,
        type: "square"
    }
];

// Initialize event listeners
document.addEventListener('DOMContentLoaded', () => {
    initializeCards();
    initializeControls();
    loadFavorites();
});

function initializeCards() {
    const cards = document.querySelectorAll('.glass-card');
    
    cards.forEach((card, index) => {
        const playBtn = card.querySelector('.play-btn');
        const soundId = index + 1;
        
        playBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleSound(soundId, card);
        });

        card.addEventListener('dblclick', () => {
            toggleFavorite(soundId, card);
        });
    });
}

function toggleSound(soundId, card) {
    const playBtn = card.querySelector('.play-btn');
    
    if (currentlyPlaying.has(soundId)) {
        stopSound(soundId);
        playBtn.classList.remove('playing');
    } else {
        playSound(soundId);
        playBtn.classList.add('playing');
    }
}

function playSound(soundId) {
    const sound = glassSounds[soundId - 1];
    const startTime = audioContext.currentTime;
    const endTime = startTime + sound.duration;
    const volume = parseFloat(document.getElementById('volume-control').value) / 100;

    // Create master gain
    const masterGain = audioContext.createGain();
    masterGain.gain.setValueAtTime(volume, startTime);
    masterGain.gain.exponentialRampToValueAtTime(0.01, endTime);
    masterGain.connect(audioContext.destination);

    // Create oscillators for each frequency
    sound.frequencies.forEach((freq, index) => {
        const osc = audioContext.createOscillator();
        const gain = audioContext.createGain();
        
        osc.type = sound.type;
        osc.frequency.setValueAtTime(freq, startTime);
        osc.frequency.exponentialRampToValueAtTime(freq * 0.5, endTime);
        
        gain.gain.setValueAtTime(0.3 / sound.frequencies.length, startTime);
        gain.gain.exponentialRampToValueAtTime(0.001, endTime);
        
        osc.connect(gain);
        gain.connect(masterGain);
        
        osc.start(startTime);
        osc.stop(endTime);
    });

    // Add reverb effect
    const convolver = audioContext.createConvolver();
    createImpulseResponse().then(buffer => {
        convolver.buffer = buffer;
        masterGain.connect(convolver);
        convolver.connect(audioContext.destination);
    });

    currentlyPlaying.add(soundId);
    totalPlays++;
    updateStats();

    // Remove from playing set after duration
    setTimeout(() => {
        currentlyPlaying.delete(soundId);
        updatePlayButton(soundId);
    }, sound.duration * 1000);
}

function stopSound(soundId) {
    currentlyPlaying.delete(soundId);
    updatePlayButton(soundId);
}

function updatePlayButton(soundId) {
    const card = document.querySelector(`[data-sound="${soundId}"]`);
    if (card) {
        const btn = card.querySelector('.play-btn');
        btn.classList.remove('playing');
    }
}

function toggleFavorite(soundId, card) {
    if (favorites.has(soundId)) {
        favorites.delete(soundId);
        card.style.borderColor = 'var(--glass-blue)';
    } else {
        favorites.add(soundId);
        card.style.borderColor = 'var(--gold)';
    }
    
    saveFavorites();
    updateStats();
}

function updateStats() {
    document.getElementById('total-plays').textContent = totalPlays;
    document.getElementById('favorite-count').textContent = favorites.size;
}

function saveFavorites() {
    localStorage.setItem('glassSoundFavorites', JSON.stringify(Array.from(favorites)));
}

function loadFavorites() {
    const saved = localStorage.getItem('glassSoundFavorites');
    if (saved) {
        favorites = new Set(JSON.parse(saved));
        favorites.forEach(id => {
            const card = document.querySelector(`[data-sound="${id}"]`);
            if (card) {
                card.style.borderColor = 'var(--gold)';
            }
        });
        updateStats();
    }
}

function initializeControls() {
    document.getElementById('play-all').addEventListener('click', playAllSounds);
    document.getElementById('stop-all').addEventListener('click', stopAllSounds);
    document.getElementById('volume-control').addEventListener('change', updateVolume);
}

function playAllSounds() {
    for (let i = 1; i <= 10; i++) {
        setTimeout(() => {
            playSound(i);
        }, (i - 1) * 400);
    }
}

function stopAllSounds() {
    currentlyPlaying.forEach(id => {
        stopSound(id);
    });
    currentlyPlaying.clear();
    document.querySelectorAll('.play-btn').forEach(btn => {
        btn.classList.remove('playing');
    });
}

function updateVolume(e) {
    // Volume is applied in playSound function
    console.log('Volume:', e.target.value);
}

// Create impulse response for reverb
async function createImpulseResponse() {
    const rate = audioContext.sampleRate;
    const length = rate * 2;
    const impulse = audioContext.createBuffer(2, length, rate);
    const left = impulse.getChannelData(0);
    const right = impulse.getChannelData(1);
    
    for (let i = 0; i < length; i++) {
        left[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / length, 2);
        right[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / length, 2);
    }
    
    return impulse;
}

// Keyboard controls
document.addEventListener('keydown', (e) => {
    const num = parseInt(e.key);
    if (num >= 1 && num <= 9) {
        const card = document.querySelector(`[data-sound="${num}"]`);
        if (card) toggleSound(num, card);
    }
});
