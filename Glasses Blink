     ============================================================ */
  const glassTypes = {
    wine: {
      name: 'Wine',
      partials: [
        { mult: 1.00, gain: 0.55 },
        { mult: 2.76, gain: 0.32 },
        { mult: 5.40, gain: 0.16 },
        { mult: 8.93, gain: 0.07 }
      ],
      decay: 4.5,
      glow: 'rgba(255, 230, 180, 0.7)',
      glowSoft: 'rgba(255, 200, 140, 0.3)',
      glowInner: 'rgba(255, 230, 180, 0.5)',
      orbColor: 'rgba(255, 230, 180, 0.9)',
      pitchShift: 0
    },
    tumbler: {
      name: 'Tumbler',
      partials: [
        { mult: 1.00, gain: 0.65 },
        { mult: 2.40, gain: 0.22 },
        { mult: 4.50, gain: 0.10 },
        { mult: 6.80, gain: 0.04 }
      ],
      decay: 1.8,
      glow: 'rgba(160, 220, 255, 0.7)',
      glowSoft: 'rgba(120, 180, 255, 0.3)',
      glowInner: 'rgba(160, 220, 255, 0.5)',
      orbColor: 'rgba(160, 220, 255, 0.9)',
      pitchShift: -0.5
    },
    flute: {
      name: 'Flute',
      partials: [
        { mult: 1.00, gain: 0.45 },
        { mult: 3.00, gain: 0.35 },
        { mult: 5.80, gain: 0.20 },
        { mult: 9.50, gain: 0.10 }
      ],
      decay: 5.5,
      glow: 'rgba(255, 200, 230, 0.7)',
      glowSoft: 'rgba(255, 170, 220, 0.3)',
      glowInner: 'rgba(255, 200, 230, 0.5)',
      orbColor: 'rgba(255, 200, 230, 0.9)',
      pitchShift: 0.5
    },
    crystal: {
      name: 'Crystal',
      partials: [
        { mult: 1.00,  gain: 0.45 },
        { mult: 2.76,  gain: 0.30 },
        { mult: 5.40,  gain: 0.20 },
        { mult: 8.93,  gain: 0.12 },
        { mult: 12.50, gain: 0.06 }
      ],
      decay: 6.5,
      glow: 'rgba(220, 255, 255, 0.8)',
      glowSoft: 'rgba(200, 240, 255, 0.35)',
      glowInner: 'rgba(220, 255, 255, 0.55)',
      orbColor: 'rgba(220, 255, 255, 0.95)',
      pitchShift: 0
    }
  };

  /* ============================================================
     PITCH MAPPING — water level <-> frequency
     ============================================================ */
  const targetFreqs = [261.63, 293.66, 329.63, 392.00, 440.00, 523.25, 587.33, 659.25];
  function freqToWaterLevel(freq) { return 100 - 50 * Math.log2(freq / 220); }
  function waterLevelToFreq(lvl)  { return 220 * Math.pow(2, (100 - lvl) / 50); }

  const keys = ['A','S','D','F','G','H','J','K'];
  const glasses = targetFreqs.map((f, i) => ({
    waterLevel: freqToWaterLevel(f),
    key: keys[i]
  }));

  /* ============================================================
     AUDIO ENGINE
     ============================================================ */
  let audioCtx = null;
  let masterBus = null;
  let reverbNode = null;
  let masterVolume = 0.7;

  function initAudio() {
    if (audioCtx) return;
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    // Algorithmic reverb impulse
    const len = audioCtx.sampleRate * 2.4;
    const impulse = audioCtx.createBuffer(2, len, audioCtx.sampleRate);
    for (let ch = 0; ch < 2; ch++) {
      const data = impulse.getChannelData(ch);
      for (let i = 0; i < len; i++) {
        data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / len, 2.5);
      }
    }
    reverbNode = audioCtx.createConvolver();
    reverbNode.buffer = impulse;

    const reverbGain = audioCtx.createGain();
    reverbGain.gain.value = 0.35;

    masterBus = audioCtx.createGain();
    masterBus.gain.value = masterVolume;

    masterBus.connect(audioCtx.destination);
    masterBus.connect(reverbNode);
    reverbNode.connect(reverbGain);
    reverbGain.connect(audioCtx.destination);
  }

  // Tap (struck rim) — natural exponential decay
  function playTap(freq, type) {
    initAudio();
    const cfg = glassTypes[type];
    const ac = audioCtx;
    const now = ac.currentTime;
    const f = freq * Math.pow(2, cfg.pitchShift / 12);

    const env = ac.createGain();
    env.gain.setValueAtTime(0, now);
    env.gain.linearRampToValueAtTime(0.45, now + 0.005);
    env.gain.exponentialRampToValueAtTime(0.001, now + cfg.decay);
    env.connect(masterBus);

    cfg.partials.forEach((p, idx) => {
      const osc = ac.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = f * p.mult * (1 + idx * 0.0008);
      const g = ac.createGain();
      g.gain.value = p.gain;
      osc.connect(g).connect(env);
      osc.start(now);
      osc.stop(now + cfg.decay + 0.5);
    });
  }

  // Sustain (rim-rub) — continuous tone with vibrato; returns stop()
  function playSustain(freq, type) {
    initAudio();
    const cfg = glassTypes[type];
    const ac = audioCtx;
    const now = ac.currentTime;
    const f = freq * Math.pow(2, cfg.pitchShift / 12);

    const env = ac.createGain();
    env.gain.setValueAtTime(0, now);
    env.gain.linearRampToValueAtTime(0.18, now + 0.25);
    env.connect(masterBus);

    const lfo = ac.createOscillator();
    lfo.frequency.value = 5.2;
    const lfoGain = ac.createGain();
    lfoGain.gain.value = f * 0.0028; // ~5 cents vibrato
    lfo.connect(lfoGain);
    lfo.start(now);

    const oscs = [];
    cfg.partials.slice(0, 3).forEach((p, idx) => {
      const osc = ac.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = f * p.mult * (1 + idx * 0.0008);
      lfoGain.connect(osc.frequency);
      const g = ac.createGain();
      g.gain.value = p.gain * 0.9;
      osc.connect(g).connect(env);
      osc.start(now);
      oscs.push(osc);
    });

    let stopped = false;
    return function stop() {
      if (stopped) return;
      stopped = true;
      const t = ac.currentTime;
      env.gain.cancelScheduledValues(t);
      env.gain.setValueAtTime(env.gain.value, t);
      env.gain.exponentialRampToValueAtTime(0.001, t + 0.6);
      oscs.forEach(o => o.stop(t + 0.7));
      lfo.stop(t + 0.7);
    };
  }

  /* ============================================================
     STATE
     ============================================================ */
  let currentType = 'wine';
  let mode = 'play';

  let recording = false;
  let recordStart = 0;
  let recordedEvents = [];
  let looping = false;
  let loopTimeouts = [];

  const activeSustains = {};

  /* ============================================================
     DOM REFS
     ============================================================ */
  const glassRow      = document.getElementById('glassRow');
  const tabs          = document.getElementById('tabs');
  const recordBtn     = document.getElementById('recordBtn');
  const playBtn       = document.getElementById('playBtn');
  const clearBtn      = document.getElementById('clearBtn');
  const volSlider     = document.getElementById('volSlider');
  const playModeBtn   = document.getElementById('playMode');
  const tuneModeBtn   = document.getElementById('tuneMode');
  const hint          = document.getElementById('hint');
  const aboutBtn      = document.getElementById('aboutBtn');
  const aboutOverlay  = document.getElementById('aboutOverlay');
  const aboutClose    = document.getElementById('aboutClose');

  /* ============================================================
     BUILD GLASSES
     ============================================================ */
  function buildGlasses() {
    glassRow.innerHTML = '';
    const cfg = glassTypes[currentType];
    glasses.forEach((g, i) => {
      const el = document.createElement('div');
      el.className = `glass ${currentType}`;
      el.dataset.index = i;
      el.style.setProperty('--glow', cfg.glow);
      el.style.setProperty('--glow-soft', cfg.glowSoft);
      el.style.setProperty('--glow-inner', cfg.glowInner);
      el.innerHTML = `
        <div class="freq-label">${Math.round(waterLevelToFreq(g.waterLevel))} Hz</div>
        <div class="bowl"><div class="water" style="height:${g.waterLevel}%"></div></div>
        <div class="stem"></div>
        <div class="base"></div>
        <div class="key-label">${g.key}</div>
      `;
      glassRow.appendChild(el);
    });
  }

  /* ============================================================
     INTERACTIONS — orbs, notes, tuning, glissando
     ============================================================ */
  function spawnBlinkOrb(rect, color) {
    const orb = document.createElement('div');
    orb.className = 'blink-orb';
    orb.style.left = (rect.left + rect.width / 2 - 3) + 'px';
    orb.style.top  = (rect.top + 20) + 'px';
    if (color) {
      orb.style.background = color;
      orb.style.boxShadow = `0 0 20px 4px ${color}`;
    }
    document.body.appendChild(orb);
    setTimeout(() => orb.remove(), 2000);
  }

  function startNote(i) {
    const g = glasses[i];
    const freq = waterLevelToFreq(g.waterLevel);
    playTap(freq, currentType);
    const stopSustain = playSustain(freq, currentType);
    activeSustains[i] = stopSustain;

    const el = glassRow.children[i];
    if (el) {
      el.classList.add('playing');
      spawnBlinkOrb(el.getBoundingClientRect(), glassTypes[currentType].orbColor);
      setTimeout(() => el.classList.remove('playing'), 700);
    }

    if (recording) {
      recordedEvents.push({
        type: 'start', index: i, glassType: currentType, freq,
        time: performance.now() - recordStart
      });
    }
  }

  function endNote(i) {
    if (activeSustains[i]) {
      activeSustains[i]();
      delete activeSustains[i];
      if (recording) {
        recordedEvents.push({ type: 'end', index: i, time: performance.now() - recordStart });
      }
    }
  }

  function endAllNotes() {
    Object.keys(activeSustains).forEach(k => {
      activeSustains[k]();
      delete activeSustains[k];
    });
  }

  // Tune mode water dragging
  let tuningGlass = null;
  let tuneStartY = 0;
  let tuneStartLevel = 0;

  function onPointerDown(e, idx) {
    if (mode === 'tune') {
      tuningGlass = idx;
      tuneStartY = e.clientY;
      tuneStartLevel = glasses[idx].waterLevel;
      e.preventDefault();
      return;
    }
    startNote(idx);
    e.preventDefault();
  }

  function onPointerMove(e) {
    if (mode === 'tune' && tuningGlass !== null) {
      const dy = e.clientY - tuneStartY;
      const newLevel = Math.max(2, Math.min(98, tuneStartLevel + dy * 0.4));
      glasses[tuningGlass].waterLevel = newLevel;
      const el = glassRow.children[tuningGlass];
      if (el) {
        const water = el.querySelector('.water');
        if (water) water.style.height = newLevel + '%';
        const lbl = el.querySelector('.freq-label');
        if (lbl) lbl.textContent = `${Math.round(waterLevelToFreq(newLevel))} Hz`;
      }
      return;
    }

    if (mode === 'play') {
      // Glissando: while a note is held, sweeping over a new glass triggers it
      if (Object.keys(activeSustains).length === 0) return;
      const target = document.elementFromPoint(e.clientX, e.clientY);
      if (!target) return;
      const glassEl = target.closest('.glass');
      if (!glassEl) return;
      const idx = parseInt(glassEl.dataset.index, 10);
      if (isNaN(idx)) return;
      if (activeSustains[idx]) return;
      startNote(idx);
    }
  }

  function onPointerUp() {
    if (mode === 'tune') { tuningGlass = null; return; }
    endAllNotes();
  }

  glassRow.addEventListener('pointerdown', (e) => {
    const glassEl = e.target.closest('.glass');
    if (!glassEl) return;
    const idx = parseInt(glassEl.dataset.index, 10);
    if (isNaN(idx)) return;
    onPointerDown(e, idx);
  });
  document.addEventListener('pointermove', onPointerMove);
  document.addEventListener('pointerup', onPointerUp);
  document.addEventListener('pointercancel', onPointerUp);

  // Keyboard
  const keysDown = {};
  document.addEventListener('keydown', (e) => {
    if (e.repeat) return;
    const k = e.key.toUpperCase();
    const idx = keys.indexOf(k);
    if (idx === -1) return;
    if (keysDown[idx]) return;
    keysDown[idx] = true;
    e.preventDefault();
    startNote(idx);
  });
  document.addEventListener('keyup', (e) => {
    const k = e.key.toUpperCase();
    const idx = keys.indexOf(k);
    if (idx === -1) return;
    keysDown[idx] = false;
    endNote(idx);
  });

  /* ============================================================
     TABS / MODE / RECORDING / VOLUME / ABOUT
     ============================================================ */
  tabs.addEventListener('click', (e) => {
    const t = e.target.closest('.tab');
    if (!t) return;
    tabs.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    currentType = t.dataset.type;
    endAllNotes();
    buildGlasses();
  });

  function setMode(m) {
    mode = m;
    document.body.classList.toggle('tune-mode', mode === 'tune');
    playModeBtn.classList.toggle('active', mode === 'play');
    tuneModeBtn.classList.toggle('active', mode === 'tune');
    hint.textContent = (mode === 'tune')
      ? 'drag a glass up or down to change its water level'
      : 'tap a glass · hold to ring · drag across to glissando · keys A–K';
    endAllNotes();
  }
  playModeBtn.addEventListener('click', () => setMode('play'));
  tuneModeBtn.addEventListener('click', () => setMode('tune'));

  recordBtn.addEventListener('click', () => {
    initAudio();
    if (!recording) {
      recordedEvents = [];
      recording = true;
      recordStart = performance.now();
      recordBtn.classList.add('recording');
      recordBtn.textContent = 'Stop';
    } else {
      recording = false;
      recordBtn.classList.remove('recording');
      recordBtn.textContent = 'Record';
    }
  });

  playBtn.addEventListener('click', () => {
    if (looping) {
      looping = false;
      loopTimeouts.forEach(t => clearTimeout(t));
      loopTimeouts = [];
      endAllNotes();
      playBtn.classList.remove('looping');
      playBtn.textContent = 'Play Loop';
      return;
    }
    if (recordedEvents.length === 0) return;
    looping = true;
    playBtn.classList.add('looping');
    playBtn.textContent = 'Stop Loop';

    function playLoop() {
      if (!looping) return;
      const last = recordedEvents[recordedEvents.length - 1];
      const totalDur = last.time + 1200;
      const liveStops = {};

      recordedEvents.forEach(ev => {
        const t = setTimeout(() => {
          if (!looping) return;
          if (ev.type === 'start') {
            const cfg = glassTypes[ev.glassType] || glassTypes[currentType];
            playTap(ev.freq, ev.glassType);
            const stop = playSustain(ev.freq, ev.glassType);
            liveStops[ev.index] = stop;
            if (ev.glassType === currentType) {
              const el = glassRow.children[ev.index];
              if (el) {
                el.classList.add('playing');
                spawnBlinkOrb(el.getBoundingClientRect(), cfg.orbColor);
                setTimeout(() => el.classList.remove('playing'), 700);
              }
            }
          } else if (ev.type === 'end') {
            if (liveStops[ev.index]) {
              liveStops[ev.index]();
              delete liveStops[ev.index];
            }
          }
        }, ev.time);
        loopTimeouts.push(t);
      });
      const t = setTimeout(playLoop, totalDur);
      loopTimeouts.push(t);
    }
    playLoop();
  });

  clearBtn.addEventListener('click', () => {
    recordedEvents = [];
    looping = false;
    loopTimeouts.forEach(t => clearTimeout(t));
    loopTimeouts = [];
    endAllNotes();
    playBtn.classList.remove('looping');
    playBtn.textContent = 'Play Loop';
    if (recording) {
      recording = false;
      recordBtn.classList.remove('recording');
      recordBtn.textContent = 'Record';
    }
  });

  volSlider.addEventListener('input', () => {
    masterVolume = parseInt(volSlider.value, 10) / 100;
    if (masterBus) masterBus.gain.setValueAtTime(masterVolume, audioCtx.currentTime);
  });

  // About panel
  aboutBtn.addEventListener('click', () => aboutOverlay.classList.add('open'));
  aboutClose.addEventListener('click', () => aboutOverlay.classList.remove('open'));
  aboutOverlay.addEventListener('click', (e) => {
    if (e.target === aboutOverlay) aboutOverlay.classList.remove('open');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') aboutOverlay.classList.remove('open');
  });

  /* ============================================================
     STARFIELD
     ============================================================ */
  const starsEl = document.getElementById('stars');
  for (let i = 0; i < 60; i++) {
    const s = document.createElement('span');
    s.style.left = Math.random() * 100 + '%';
    s.style.top  = Math.random() * 100 + '%';
    s.style.animationDelay = (Math.random() * 3) + 's';
    s.style.opacity = 0.3 + Math.random() * 0.6;
    starsEl.appendChild(s);
  }

  // Initial render
  buildGlasses();
</script>
</body>
</html>




